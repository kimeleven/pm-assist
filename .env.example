# NeonDB - Pooled connection (앱 런타임용)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&pgbouncer=true"

# NeonDB - Direct connection (Prisma 마이그레이션용)
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT 시크릿 (최소 32자 이상 랜덤 문자열)
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"

# Vercel Blob (파일 업로드)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Kakao Maps JavaScript API Key (더 이상 사용하지 않음 — Leaflet + OpenStreetMap으로 교체됨)
# NEXT_PUBLIC_KAKAO_APP_KEY="your-kakao-javascript-app-key"
